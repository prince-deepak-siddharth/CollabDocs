# ============================================
#  MASTER CONFIGURATION — CollabDocs
# ============================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ----------- APP MODE -----------
APP_ENV=development
# Options: development | production

# ----------- BACKEND -----------
BACKEND_HOST=localhost
BACKEND_PORT=8080
BACKEND_URL=http://localhost:8080

# ----------- FRONTEND -----------
FRONTEND_HOST=localhost
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ----------- DATABASE -----------
DATABASE_URL=postgresql://neondb_owner:npg_j3FEqnmTuis2@ep-aged-breeze-ahxgqcd8-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ----------- JWT / AUTH -----------
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_HOURS=72

# ----------- MASTER TOKEN -----------
MASTER_TOKEN=change-me-to-a-random-string

# ----------- CORS -----------
ALLOWED_ORIGINS=http://localhost:3000

# ----------- WEBSOCKET -----------
WS_MAX_CONNECTIONS=100
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
